# GEMINI_API_KEY: Optional server-side fallback for Gemini.
# Users can also paste their key in the Settings UI (preferred).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# XAI_API_KEY: Optional server-side fallback for xAI Grok.
# Users can paste their key in the Settings UI (preferred).
XAI_API_KEY="MY_XAI_API_KEY"

# APP_URL: The URL where this applet is hosted (auto-injected by AI Studio / Cloud Run).
APP_URL="MY_APP_URL"
